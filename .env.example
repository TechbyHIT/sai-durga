# Production URL
NEXT_PUBLIC_SITE_URL=https://saidurgainvisiblegrills.in

# Disable Next.js image optimizer disk cache (static images served as-is)
NEXT_IMAGE_UNOPTIMIZED=1

# Node memory ceiling (MB)
NODE_OPTIONS=--max-old-space-size=384

# PM2 (no Docker) — optional overrides for ecosystem.config.cjs
# PM2_APP_NAME=sai-durga
PORT=3002
